# Aurigen Pipeline — Environment Variables
# Copy this to .env and fill in your values:
#   cp pipeline/.env.example .env

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Override the git branch for pipeline commits
# PIPELINE_BRANCH=claude/reorganize-repo-structure-wth2a

# Optional: Override the pipeline interval (ms). Default: 6 hours
# PIPELINE_INTERVAL_MS=21600000
